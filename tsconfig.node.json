{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": true,
    "outDir": "./.tsbuild/node",
    "declarationDir": "./.tsbuild/node",
    "tsBuildInfoFile": "./.tsbuild/node/.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "scripts/**/*.ts",
    "src/data/**/*.ts",
    "src/types.ts"
  ]
}
